# Sub2API 服务地址，不要以 / 结尾
SUB2API_BASE_URL=https://sub2api.example.com

# 认证方式：
# - user_jwt：登录 Sub2API 后拿到的用户 JWT，走 /api/v1/usage/stats
# - admin_api_key：管理员 API Key，形如 admin-...，走 /api/v1/admin/usage/stats
SUB2API_AUTH_TYPE=admin_api_key

# 对应 SUB2API_AUTH_TYPE 填：
# - user_jwt：用户 JWT/token
# - admin_api_key：管理员 API Key，形如 admin-...
SUB2API_TOKEN=your_sub2api_user_token

# 钉钉群自定义机器人 webhook
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_access_token

# 如果钉钉机器人安全设置开启了“加签”，填 secret；未开启可留空。
DINGTALK_SECRET=SECxxxxxxxxxxxxxxxx

# 统计和日期计算时区
REPORT_TIMEZONE=Asia/Shanghai

# 报告标题
REPORT_TITLE=Sub2API 昨日用量

# 累计产出统计：基准值 + 每日实际费用累加。
# 同一天重复执行不会重复累加，会覆盖当天的实际费用并重新计算累计值。
CUMULATIVE_BASE_ACTUAL_COST=2551
CUMULATIVE_STATE_FILE=data/cumulative-actual-cost.json
